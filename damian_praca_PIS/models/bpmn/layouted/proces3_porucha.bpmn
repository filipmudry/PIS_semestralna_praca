<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_Proces3" targetNamespace="http://bpmn.io/schema/bpmn" exporter="bpmn-js (https://demo.bpmn.io)" exporterVersion="18.6.1">
  <bpmn:message id="Message_ToTroubleshooting" name="Prechod na riešenie poruchy" />
  <bpmn:message id="Message_OutageNotified" name="Odstávka nahlásená" />
  <bpmn:message id="Message_SparePartArrived" name="Náhradný diel doručený" />
  <bpmn:message id="Message_ReconnectionApproved" name="Opätovné pripojenie schválené" />
  <bpmn:message id="Message_ReconnectionDenied" name="Opätovné pripojenie zamietnuté" />
  <bpmn:message id="Message_OperationResumed" name="Prevádzka obnovená" />
  <bpmn:process id="Process_Troubleshooting" name="Proces 3 – Riešenie poruchy a obnovenie prevádzky" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Proces3">
      <bpmn:lane id="Lane3_ControlSystem" name="Riadiaci systém">
        <bpmn:flowNodeRef>StartEvent_FaultRecording</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_FaultDetection</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_RecordingReport</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_CollectDiagnostics</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_EmergencyShutdown</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ShutdownMerged</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_PostShutdownSplit</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_CreateServiceTask</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_NotifyDispatcherOutage</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_PostShutdownJoin</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>SubProcess_DiagnosticsRepair</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BoundaryEvent_RepairTimeout</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_RequestReconnection</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_WaitReconnectionResponse</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_ReconnectionApproved</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_ReconnectionDenied</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_ReconnectionTimeout</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_RestartProduction</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_SendResumptionNotification</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_OperationResumed</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane3_Operator" name="Operátor elektrárne">
        <bpmn:flowNodeRef>Activity_EvaluationSituation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_IsFaultCritical</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_PlannedShutdown</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_SecureSite</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_RescheduleReconnection</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_WaitBeforeRetry</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_CallDispatcher</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_EscalateProblem</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_EscalationHandled</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane3_Dispatcher" name="Dispečer distribučnej siete">
        <bpmn:flowNodeRef>Activity_RecordOutage</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_RecordResumption</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane3_ServiceTechnician" name="Servisný technik">
        <bpmn:flowNodeRef>StartEvent_SubProcessStart</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_Diagnostics</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_SparePartNeeded</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_WaitForSparePart</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_SparePartArrived</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_SparePartDelayed</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_ChaseSparePart</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_ReplacePart</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_Correction</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_FunctionalityTest</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_DeviceOk</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_SubProcessEnd</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_FaultRecording" name="Porucha nahlásená">
      <bpmn:outgoing>Flow_Start_To_FaultDetection</bpmn:outgoing>
      <bpmn:messageEventDefinition messageRef="Message_ToTroubleshooting" />
    </bpmn:startEvent>
    <bpmn:serviceTask id="Activity_FaultDetection" name="Deteguj poruchu">
      <bpmn:incoming>Flow_Start_To_FaultDetection</bpmn:incoming>
      <bpmn:outgoing>Flow_FaultDetection_To_RecordingReport</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Activity_RecordingReport" name="Zaznamenaj hlásenie">
      <bpmn:incoming>Flow_FaultDetection_To_RecordingReport</bpmn:incoming>
      <bpmn:outgoing>Flow_RecordingReport_To_CollectDiagnostics</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Activity_CollectDiagnostics" name="Zhromaždi diagnostické údaje">
      <bpmn:incoming>Flow_RecordingReport_To_CollectDiagnostics</bpmn:incoming>
      <bpmn:outgoing>Flow_CollectDiagnostics_To_EvaluationSituation</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="Activity_EvaluationSituation" name="Vyhodnoť situáciu">
      <bpmn:incoming>Flow_CollectDiagnostics_To_EvaluationSituation</bpmn:incoming>
      <bpmn:outgoing>Flow_EvaluationSituation_To_IsFaultCritical</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_IsFaultCritical" name="Je porucha kritická?">
      <bpmn:incoming>Flow_EvaluationSituation_To_IsFaultCritical</bpmn:incoming>
      <bpmn:outgoing>Flow_IsFaultCritical_Yes_To_EmergencyShutdown</bpmn:outgoing>
      <bpmn:outgoing>Flow_IsFaultCritical_No_To_PlannedShutdown</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Activity_EmergencyShutdown" name="Núdzové zastavenie turbíny">
      <bpmn:incoming>Flow_IsFaultCritical_Yes_To_EmergencyShutdown</bpmn:incoming>
      <bpmn:outgoing>Flow_EmergencyShutdown_To_ShutdownMerged</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="Activity_PlannedShutdown" name="Plánované odstavenie">
      <bpmn:incoming>Flow_IsFaultCritical_No_To_PlannedShutdown</bpmn:incoming>
      <bpmn:outgoing>Flow_PlannedShutdown_To_ShutdownMerged</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_ShutdownMerged" name="Turbína odstavená">
      <bpmn:incoming>Flow_EmergencyShutdown_To_ShutdownMerged</bpmn:incoming>
      <bpmn:incoming>Flow_PlannedShutdown_To_ShutdownMerged</bpmn:incoming>
      <bpmn:outgoing>Flow_ShutdownMerged_To_PostShutdownSplit</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:parallelGateway id="Gateway_PostShutdownSplit" name="Príprava servisu (paralelne)">
      <bpmn:incoming>Flow_ShutdownMerged_To_PostShutdownSplit</bpmn:incoming>
      <bpmn:outgoing>Flow_PostShutdownSplit_To_CreateServiceTask</bpmn:outgoing>
      <bpmn:outgoing>Flow_PostShutdownSplit_To_NotifyDispatcherOutage</bpmn:outgoing>
      <bpmn:outgoing>Flow_PostShutdownSplit_To_SecureSite</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:serviceTask id="Activity_CreateServiceTask" name="Vytvor servisnú úlohu">
      <bpmn:incoming>Flow_PostShutdownSplit_To_CreateServiceTask</bpmn:incoming>
      <bpmn:outgoing>Flow_CreateServiceTask_To_PostShutdownJoin</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sendTask id="Activity_NotifyDispatcherOutage" name="Informuj DDS o odstávke">
      <bpmn:incoming>Flow_PostShutdownSplit_To_NotifyDispatcherOutage</bpmn:incoming>
      <bpmn:outgoing>Flow_NotifyDispatcherOutage_To_RecordOutage</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:userTask id="Activity_RecordOutage" name="Zaeviduj odstávku v sieti">
      <bpmn:incoming>Flow_NotifyDispatcherOutage_To_RecordOutage</bpmn:incoming>
      <bpmn:outgoing>Flow_RecordOutage_To_PostShutdownJoin</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Activity_SecureSite" name="Zabezpeč prístup a bezpečnosť">
      <bpmn:incoming>Flow_PostShutdownSplit_To_SecureSite</bpmn:incoming>
      <bpmn:outgoing>Flow_SecureSite_To_PostShutdownJoin</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:parallelGateway id="Gateway_PostShutdownJoin" name="Servis pripravený">
      <bpmn:incoming>Flow_CreateServiceTask_To_PostShutdownJoin</bpmn:incoming>
      <bpmn:incoming>Flow_RecordOutage_To_PostShutdownJoin</bpmn:incoming>
      <bpmn:incoming>Flow_SecureSite_To_PostShutdownJoin</bpmn:incoming>
      <bpmn:outgoing>Flow_PostShutdownJoin_To_SubProcess</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:subProcess id="SubProcess_DiagnosticsRepair" name="Diagnostika a oprava">
      <bpmn:incoming>Flow_PostShutdownJoin_To_SubProcess</bpmn:incoming>
      <bpmn:outgoing>Flow_SubProcess_To_RequestReconnection</bpmn:outgoing>
      <bpmn:startEvent id="StartEvent_SubProcessStart" name="Začni diagnostiku">
        <bpmn:outgoing>Flow_SubStart_To_Diagnostics</bpmn:outgoing>
      </bpmn:startEvent>
      <bpmn:manualTask id="Activity_Diagnostics" name="Diagnostika na mieste">
        <bpmn:incoming>Flow_SubStart_To_Diagnostics</bpmn:incoming>
        <bpmn:outgoing>Flow_Diagnostics_To_SparePartNeeded</bpmn:outgoing>
      </bpmn:manualTask>
      <bpmn:exclusiveGateway id="Gateway_SparePartNeeded" name="Potrebný náhradný diel?">
        <bpmn:incoming>Flow_Diagnostics_To_SparePartNeeded</bpmn:incoming>
        <bpmn:outgoing>Flow_SparePartNeeded_No_To_Correction</bpmn:outgoing>
        <bpmn:outgoing>Flow_SparePartNeeded_Yes_To_WaitForSparePart</bpmn:outgoing>
      </bpmn:exclusiveGateway>
      <bpmn:eventBasedGateway id="Gateway_WaitForSparePart" name="Čakaj na diel">
        <bpmn:incoming>Flow_SparePartNeeded_Yes_To_WaitForSparePart</bpmn:incoming>
        <bpmn:outgoing>Flow_WaitForSparePart_To_SparePartArrived</bpmn:outgoing>
        <bpmn:outgoing>Flow_WaitForSparePart_To_SparePartDelayed</bpmn:outgoing>
      </bpmn:eventBasedGateway>
      <bpmn:intermediateCatchEvent id="Event_SparePartArrived" name="Diel doručený">
        <bpmn:incoming>Flow_WaitForSparePart_To_SparePartArrived</bpmn:incoming>
        <bpmn:outgoing>Flow_SparePartArrived_To_ReplacePart</bpmn:outgoing>
        <bpmn:messageEventDefinition messageRef="Message_SparePartArrived" />
      </bpmn:intermediateCatchEvent>
      <bpmn:intermediateCatchEvent id="Event_SparePartDelayed" name="Oneskorená dodávka">
        <bpmn:incoming>Flow_WaitForSparePart_To_SparePartDelayed</bpmn:incoming>
        <bpmn:outgoing>Flow_SparePartDelayed_To_ChaseSparePart</bpmn:outgoing>
        <bpmn:timerEventDefinition>
          <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT4H</bpmn:timeDuration>
        </bpmn:timerEventDefinition>
      </bpmn:intermediateCatchEvent>
      <bpmn:userTask id="Activity_ChaseSparePart" name="Urgencia dodávky dielu">
        <bpmn:incoming>Flow_SparePartDelayed_To_ChaseSparePart</bpmn:incoming>
        <bpmn:outgoing>Flow_ChaseSparePart_To_WaitForSparePart</bpmn:outgoing>
      </bpmn:userTask>
      <bpmn:manualTask id="Activity_ReplacePart" name="Vymeň náhradný diel">
        <bpmn:incoming>Flow_SparePartArrived_To_ReplacePart</bpmn:incoming>
        <bpmn:outgoing>Flow_ReplacePart_To_Correction</bpmn:outgoing>
      </bpmn:manualTask>
      <bpmn:manualTask id="Activity_Correction" name="Oprava/kalibrácia">
        <bpmn:incoming>Flow_SparePartNeeded_No_To_Correction</bpmn:incoming>
        <bpmn:incoming>Flow_ReplacePart_To_Correction</bpmn:incoming>
        <bpmn:outgoing>Flow_Correction_To_FunctionalityTest</bpmn:outgoing>
      </bpmn:manualTask>
      <bpmn:serviceTask id="Activity_FunctionalityTest" name="Test funkčnosti zariadenia">
        <bpmn:incoming>Flow_Correction_To_FunctionalityTest</bpmn:incoming>
        <bpmn:outgoing>Flow_FunctionalityTest_To_DeviceOk</bpmn:outgoing>
      </bpmn:serviceTask>
      <bpmn:exclusiveGateway id="Gateway_DeviceOk" name="Zariadenie v poriadku?">
        <bpmn:incoming>Flow_FunctionalityTest_To_DeviceOk</bpmn:incoming>
        <bpmn:outgoing>Flow_DeviceOk_Yes_To_SubProcessEnd</bpmn:outgoing>
        <bpmn:outgoing>Flow_DeviceOk_No_To_Correction</bpmn:outgoing>
      </bpmn:exclusiveGateway>
      <bpmn:endEvent id="EndEvent_SubProcessEnd" name="Oprava dokončená">
        <bpmn:incoming>Flow_DeviceOk_Yes_To_SubProcessEnd</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="Flow_SubStart_To_Diagnostics" sourceRef="StartEvent_SubProcessStart" targetRef="Activity_Diagnostics" />
      <bpmn:sequenceFlow id="Flow_Diagnostics_To_SparePartNeeded" sourceRef="Activity_Diagnostics" targetRef="Gateway_SparePartNeeded" />
      <bpmn:sequenceFlow id="Flow_SparePartNeeded_No_To_Correction" name="Nie" sourceRef="Gateway_SparePartNeeded" targetRef="Activity_Correction" />
      <bpmn:sequenceFlow id="Flow_SparePartNeeded_Yes_To_WaitForSparePart" name="Áno" sourceRef="Gateway_SparePartNeeded" targetRef="Gateway_WaitForSparePart" />
      <bpmn:sequenceFlow id="Flow_WaitForSparePart_To_SparePartArrived" name="Doručené" sourceRef="Gateway_WaitForSparePart" targetRef="Event_SparePartArrived" />
      <bpmn:sequenceFlow id="Flow_WaitForSparePart_To_SparePartDelayed" name="Meškanie" sourceRef="Gateway_WaitForSparePart" targetRef="Event_SparePartDelayed" />
      <bpmn:sequenceFlow id="Flow_SparePartArrived_To_ReplacePart" sourceRef="Event_SparePartArrived" targetRef="Activity_ReplacePart" />
      <bpmn:sequenceFlow id="Flow_SparePartDelayed_To_ChaseSparePart" sourceRef="Event_SparePartDelayed" targetRef="Activity_ChaseSparePart" />
      <bpmn:sequenceFlow id="Flow_ChaseSparePart_To_WaitForSparePart" sourceRef="Activity_ChaseSparePart" targetRef="Gateway_WaitForSparePart" />
      <bpmn:sequenceFlow id="Flow_ReplacePart_To_Correction" sourceRef="Activity_ReplacePart" targetRef="Activity_Correction" />
      <bpmn:sequenceFlow id="Flow_Correction_To_FunctionalityTest" sourceRef="Activity_Correction" targetRef="Activity_FunctionalityTest" />
      <bpmn:sequenceFlow id="Flow_FunctionalityTest_To_DeviceOk" sourceRef="Activity_FunctionalityTest" targetRef="Gateway_DeviceOk" />
      <bpmn:sequenceFlow id="Flow_DeviceOk_Yes_To_SubProcessEnd" name="Áno" sourceRef="Gateway_DeviceOk" targetRef="EndEvent_SubProcessEnd" />
      <bpmn:sequenceFlow id="Flow_DeviceOk_No_To_Correction" name="Nie" sourceRef="Gateway_DeviceOk" targetRef="Activity_Correction" />
    </bpmn:subProcess>
    <bpmn:boundaryEvent id="BoundaryEvent_RepairTimeout" name="Oprava trvá dlho" cancelActivity="false" attachedToRef="SubProcess_DiagnosticsRepair">
      <bpmn:outgoing>Flow_RepairTimeout_To_EscalateProblem</bpmn:outgoing>
      <bpmn:timerEventDefinition>
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT2H</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:userTask id="Activity_EscalateProblem" name="Eskaluj problém">
      <bpmn:incoming>Flow_RepairTimeout_To_EscalateProblem</bpmn:incoming>
      <bpmn:outgoing>Flow_EscalateProblem_To_EscalationHandled</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="EndEvent_EscalationHandled" name="Eskalácia vykonaná">
      <bpmn:incoming>Flow_EscalateProblem_To_EscalationHandled</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="Activity_RequestReconnection" name="Požiadaj o opätovné pripojenie">
      <bpmn:incoming>Flow_SubProcess_To_RequestReconnection</bpmn:incoming>
      <bpmn:incoming>Flow_WaitBeforeRetry_To_RequestReconnection</bpmn:incoming>
      <bpmn:incoming>Flow_CallDispatcher_To_RequestReconnection</bpmn:incoming>
      <bpmn:outgoing>Flow_RequestReconnection_To_WaitReconnectionResponse</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:eventBasedGateway id="Gateway_WaitReconnectionResponse" name="Čakaj na odpoveď DDS">
      <bpmn:incoming>Flow_RequestReconnection_To_WaitReconnectionResponse</bpmn:incoming>
      <bpmn:outgoing>Flow_WaitReconnectionResponse_To_ReconnectionApproved</bpmn:outgoing>
      <bpmn:outgoing>Flow_WaitReconnectionResponse_To_ReconnectionDenied</bpmn:outgoing>
      <bpmn:outgoing>Flow_WaitReconnectionResponse_To_ReconnectionTimeout</bpmn:outgoing>
    </bpmn:eventBasedGateway>
    <bpmn:intermediateCatchEvent id="Event_ReconnectionApproved" name="Pripojenie schválené">
      <bpmn:incoming>Flow_WaitReconnectionResponse_To_ReconnectionApproved</bpmn:incoming>
      <bpmn:outgoing>Flow_ReconnectionApproved_To_RestartProduction</bpmn:outgoing>
      <bpmn:messageEventDefinition messageRef="Message_ReconnectionApproved" />
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateCatchEvent id="Event_ReconnectionDenied" name="Pripojenie zamietnuté">
      <bpmn:incoming>Flow_WaitReconnectionResponse_To_ReconnectionDenied</bpmn:incoming>
      <bpmn:outgoing>Flow_ReconnectionDenied_To_RescheduleReconnection</bpmn:outgoing>
      <bpmn:messageEventDefinition messageRef="Message_ReconnectionDenied" />
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateCatchEvent id="Event_ReconnectionTimeout" name="Bez odpovede (timeout)">
      <bpmn:incoming>Flow_WaitReconnectionResponse_To_ReconnectionTimeout</bpmn:incoming>
      <bpmn:outgoing>Flow_ReconnectionTimeout_To_CallDispatcher</bpmn:outgoing>
      <bpmn:timerEventDefinition>
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT10M</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:intermediateCatchEvent>
    <bpmn:userTask id="Activity_RescheduleReconnection" name="Naplánuj opätovnú žiadosť">
      <bpmn:incoming>Flow_ReconnectionDenied_To_RescheduleReconnection</bpmn:incoming>
      <bpmn:outgoing>Flow_RescheduleReconnection_To_WaitBeforeRetry</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:intermediateCatchEvent id="Event_WaitBeforeRetry" name="Počkaj pred opakovaním">
      <bpmn:incoming>Flow_RescheduleReconnection_To_WaitBeforeRetry</bpmn:incoming>
      <bpmn:outgoing>Flow_WaitBeforeRetry_To_RequestReconnection</bpmn:outgoing>
      <bpmn:timerEventDefinition>
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT30M</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:intermediateCatchEvent>
    <bpmn:userTask id="Activity_CallDispatcher" name="Kontaktuj DDS">
      <bpmn:incoming>Flow_ReconnectionTimeout_To_CallDispatcher</bpmn:incoming>
      <bpmn:outgoing>Flow_CallDispatcher_To_RequestReconnection</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="Activity_RestartProduction" name="Opätovne spusti výrobu">
      <bpmn:incoming>Flow_ReconnectionApproved_To_RestartProduction</bpmn:incoming>
      <bpmn:outgoing>Flow_RestartProduction_To_SendResumptionNotification</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sendTask id="Activity_SendResumptionNotification" name="Odošli oznámenie o obnovení">
      <bpmn:incoming>Flow_RestartProduction_To_SendResumptionNotification</bpmn:incoming>
      <bpmn:outgoing>Flow_SendResumptionNotification_To_RecordResumption</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:userTask id="Activity_RecordResumption" name="Zaeviduj obnovu dodávky">
      <bpmn:incoming>Flow_SendResumptionNotification_To_RecordResumption</bpmn:incoming>
      <bpmn:outgoing>Flow_RecordResumption_To_OperationResumed</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="EndEvent_OperationResumed" name="Prevádzka obnovená">
      <bpmn:incoming>Flow_RecordResumption_To_OperationResumed</bpmn:incoming>
      <bpmn:messageEventDefinition messageRef="Message_OperationResumed" />
    </bpmn:endEvent>
    <bpmn:dataObject id="DataObject_FaultReport" />
    <bpmn:dataObjectReference id="DataObjectReference_FaultReport" name="Hlásenie poruchy" dataObjectRef="DataObject_FaultReport" />
    <bpmn:dataObject id="DataObject_ServiceTicket" />
    <bpmn:dataObjectReference id="DataObjectReference_ServiceTicket" name="Servisná úloha" dataObjectRef="DataObject_ServiceTicket" />
    <bpmn:dataObject id="DataObject_TestReport" />
    <bpmn:dataObjectReference id="DataObjectReference_TestReport" name="Výsledok testu" dataObjectRef="DataObject_TestReport" />
    <bpmn:sequenceFlow id="Flow_Start_To_FaultDetection" sourceRef="StartEvent_FaultRecording" targetRef="Activity_FaultDetection" />
    <bpmn:sequenceFlow id="Flow_FaultDetection_To_RecordingReport" sourceRef="Activity_FaultDetection" targetRef="Activity_RecordingReport" />
    <bpmn:sequenceFlow id="Flow_RecordingReport_To_CollectDiagnostics" sourceRef="Activity_RecordingReport" targetRef="Activity_CollectDiagnostics" />
    <bpmn:sequenceFlow id="Flow_CollectDiagnostics_To_EvaluationSituation" sourceRef="Activity_CollectDiagnostics" targetRef="Activity_EvaluationSituation" />
