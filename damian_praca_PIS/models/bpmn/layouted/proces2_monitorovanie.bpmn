<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_Proces2" targetNamespace="http://bpmn.io/schema/bpmn" exporter="bpmn-js (https://demo.bpmn.io)" exporterVersion="18.6.1">
  <bpmn:message id="Message_ProductionStarted" name="Výroba spustená" />
  <bpmn:message id="Message_DeviationDetected" name="Odchýlka detegovaná" />
  <bpmn:message id="Message_CurtailmentRequest" name="Požiadavka na reguláciu výkonu" />
  <bpmn:message id="Message_ToTroubleshooting" name="Prechod na riešenie poruchy" />
  <bpmn:process id="Process_Monitoring" name="Proces 2 – Monitorovanie a regulácia prevádzky" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Proces2">
      <bpmn:lane id="Lane2_ControlSystem" name="Riadiaci systém">
        <bpmn:flowNodeRef>StartEvent_MonitoringStart</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_CollectSensorData</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_PreprocessData</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ParallelMonitoringSplit</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_MonitorWindAndPower</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_MonitorTechIndicators</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ParallelMonitoringJoin</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_WaitForEvent</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_TimerInterval</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_MessageDeviationDetected</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_MessageCurtailmentRequest</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_DataEvaluation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_Stable</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_ClassifyDeviation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_SeriousDeviation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_CalcOptimalSettings</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ApplySettingsSplit</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_AdjustPitch</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_AdjustYaw</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_AdjustConverter</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ApplySettingsJoin</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_ValidateLimits</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_LimitsOk</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_SendProductionData</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_RequestOperatorIntervention</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_ApplyParameterChanges</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_LogChange</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_AdjustSetpoint</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_ConfirmCurtailmentToDispatcher</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_TransitionToTroubleshooting</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane2_Operator" name="Operátor elektrárne">
        <bpmn:flowNodeRef>Activity_ConfirmCurtailment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_ReviewDeviation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_NeedPhysicalCheck</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_PhysicalInspection</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_EditParameters</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane2_Dispatcher" name="Dispečer distribučnej siete">
        <bpmn:flowNodeRef>Activity_RecordProductionData</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_RecordCurtailment</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_MonitoringStart" name="Začiatok monitorovania">
      <bpmn:outgoing>Flow_Start_To_CollectSensorData</bpmn:outgoing>
      <bpmn:messageEventDefinition messageRef="Message_ProductionStarted" />
    </bpmn:startEvent>
    <bpmn:serviceTask id="Activity_CollectSensorData" name="Zbieraj senzorové dáta">
      <bpmn:incoming>Flow_Start_To_CollectSensorData</bpmn:incoming>
      <bpmn:outgoing>Flow_CollectSensorData_To_PreprocessData</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Activity_PreprocessData" name="Predspracuj dáta (filtrácia)">
      <bpmn:incoming>Flow_CollectSensorData_To_PreprocessData</bpmn:incoming>
      <bpmn:outgoing>Flow_PreprocessData_To_ParallelMonitoringSplit</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:parallelGateway id="Gateway_ParallelMonitoringSplit" name="Paralelné monitorovanie">
      <bpmn:incoming>Flow_PreprocessData_To_ParallelMonitoringSplit</bpmn:incoming>
      <bpmn:outgoing>Flow_ParallelMonitoringSplit_To_MonitorWindAndPower</bpmn:outgoing>
      <bpmn:outgoing>Flow_ParallelMonitoringSplit_To_MonitorTechIndicators</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:serviceTask id="Activity_MonitorWindAndPower" name="Sleduj vietor a výkon">
      <bpmn:incoming>Flow_ParallelMonitoringSplit_To_MonitorWindAndPower</bpmn:incoming>
      <bpmn:outgoing>Flow_MonitorWindAndPower_To_ParallelMonitoringJoin</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Activity_MonitorTechIndicators" name="Sleduj teploty a vibrácie">
      <bpmn:incoming>Flow_ParallelMonitoringSplit_To_MonitorTechIndicators</bpmn:incoming>
      <bpmn:outgoing>Flow_MonitorTechIndicators_To_ParallelMonitoringJoin</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:parallelGateway id="Gateway_ParallelMonitoringJoin" name="Dáta pripravené">
      <bpmn:incoming>Flow_MonitorWindAndPower_To_ParallelMonitoringJoin</bpmn:incoming>
      <bpmn:incoming>Flow_MonitorTechIndicators_To_ParallelMonitoringJoin</bpmn:incoming>
      <bpmn:outgoing>Flow_ParallelMonitoringJoin_To_WaitForEvent</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:eventBasedGateway id="Gateway_WaitForEvent" name="Čakaj na udalosť">
      <bpmn:incoming>Flow_ParallelMonitoringJoin_To_WaitForEvent</bpmn:incoming>
      <bpmn:outgoing>Flow_WaitForEvent_To_Timer</bpmn:outgoing>
      <bpmn:outgoing>Flow_WaitForEvent_To_DeviationMessage</bpmn:outgoing>
      <bpmn:outgoing>Flow_WaitForEvent_To_CurtailmentRequest</bpmn:outgoing>
    </bpmn:eventBasedGateway>
    <bpmn:intermediateCatchEvent id="Event_TimerInterval" name="Interval monitorovania">
      <bpmn:incoming>Flow_WaitForEvent_To_Timer</bpmn:incoming>
      <bpmn:outgoing>Flow_Timer_To_DataEvaluation</bpmn:outgoing>
      <bpmn:timerEventDefinition>
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT5M</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateCatchEvent id="Event_MessageDeviationDetected" name="Odchýlka detegovaná">
      <bpmn:incoming>Flow_WaitForEvent_To_DeviationMessage</bpmn:incoming>
      <bpmn:outgoing>Flow_DeviationMessage_To_DataEvaluation</bpmn:outgoing>
      <bpmn:messageEventDefinition messageRef="Message_DeviationDetected" />
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateCatchEvent id="Event_MessageCurtailmentRequest" name="Požiadavka na reguláciu výkonu">
      <bpmn:incoming>Flow_WaitForEvent_To_CurtailmentRequest</bpmn:incoming>
      <bpmn:outgoing>Flow_CurtailmentRequest_To_ConfirmCurtailment</bpmn:outgoing>
      <bpmn:messageEventDefinition messageRef="Message_CurtailmentRequest" />
    </bpmn:intermediateCatchEvent>
    <bpmn:serviceTask id="Activity_DataEvaluation" name="Vyhodnoť údaje">
      <bpmn:incoming>Flow_Timer_To_DataEvaluation</bpmn:incoming>
      <bpmn:incoming>Flow_DeviationMessage_To_DataEvaluation</bpmn:incoming>
      <bpmn:outgoing>Flow_DataEvaluation_To_StableGateway</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_Stable" name="Je prevádzka stabilná?">
      <bpmn:incoming>Flow_DataEvaluation_To_StableGateway</bpmn:incoming>
      <bpmn:outgoing>Flow_Stable_Yes_To_CalcOptimalSettings</bpmn:outgoing>
      <bpmn:outgoing>Flow_Stable_No_To_ClassifyDeviation</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:businessRuleTask id="Activity_CalcOptimalSettings" name="Vypočítaj optimálne nastavenia">
      <bpmn:incoming>Flow_Stable_Yes_To_CalcOptimalSettings</bpmn:incoming>
      <bpmn:outgoing>Flow_CalcOptimalSettings_To_ApplySettingsSplit</bpmn:outgoing>
    </bpmn:businessRuleTask>
    <bpmn:parallelGateway id="Gateway_ApplySettingsSplit" name="Aplikácia nastavení">
      <bpmn:incoming>Flow_CalcOptimalSettings_To_ApplySettingsSplit</bpmn:incoming>
      <bpmn:outgoing>Flow_ApplySettingsSplit_To_AdjustPitch</bpmn:outgoing>
      <bpmn:outgoing>Flow_ApplySettingsSplit_To_AdjustYaw</bpmn:outgoing>
      <bpmn:outgoing>Flow_ApplySettingsSplit_To_AdjustConverter</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:serviceTask id="Activity_AdjustPitch" name="Nastav uhol lopatiek (pitch)">
      <bpmn:incoming>Flow_ApplySettingsSplit_To_AdjustPitch</bpmn:incoming>
      <bpmn:outgoing>Flow_AdjustPitch_To_ApplySettingsJoin</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Activity_AdjustYaw" name="Natoč gondolu (yaw)">
      <bpmn:incoming>Flow_ApplySettingsSplit_To_AdjustYaw</bpmn:incoming>
      <bpmn:outgoing>Flow_AdjustYaw_To_ApplySettingsJoin</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Activity_AdjustConverter" name="Nastav menič/brzdy">
      <bpmn:incoming>Flow_ApplySettingsSplit_To_AdjustConverter</bpmn:incoming>
      <bpmn:outgoing>Flow_AdjustConverter_To_ApplySettingsJoin</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:parallelGateway id="Gateway_ApplySettingsJoin" name="Nastavenia aplikované">
      <bpmn:incoming>Flow_AdjustPitch_To_ApplySettingsJoin</bpmn:incoming>
      <bpmn:incoming>Flow_AdjustYaw_To_ApplySettingsJoin</bpmn:incoming>
      <bpmn:incoming>Flow_AdjustConverter_To_ApplySettingsJoin</bpmn:incoming>
      <bpmn:outgoing>Flow_ApplySettingsJoin_To_ValidateLimits</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:serviceTask id="Activity_ValidateLimits" name="Over bezpečnostné limity">
      <bpmn:incoming>Flow_ApplySettingsJoin_To_ValidateLimits</bpmn:incoming>
      <bpmn:outgoing>Flow_ValidateLimits_To_LimitsOk</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_LimitsOk" name="Limity OK?">
      <bpmn:incoming>Flow_ValidateLimits_To_LimitsOk</bpmn:incoming>
      <bpmn:outgoing>Flow_LimitsOk_Yes_To_SendProductionData</bpmn:outgoing>
      <bpmn:outgoing>Flow_LimitsOk_No_To_RequestOperatorIntervention</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sendTask id="Activity_SendProductionData" name="Odošli údaje o výrobe">
      <bpmn:incoming>Flow_LimitsOk_Yes_To_SendProductionData</bpmn:incoming>
      <bpmn:outgoing>Flow_SendProductionData_To_RecordProductionData</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:userTask id="Activity_RecordProductionData" name="Zaeviduj údaje v sieti">
      <bpmn:incoming>Flow_SendProductionData_To_RecordProductionData</bpmn:incoming>
      <bpmn:outgoing>Flow_RecordProductionData_To_CollectSensorData</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:businessRuleTask id="Activity_ClassifyDeviation" name="Klasifikuj odchýlku">
      <bpmn:incoming>Flow_Stable_No_To_ClassifyDeviation</bpmn:incoming>
      <bpmn:outgoing>Flow_ClassifyDeviation_To_SeriousDeviation</bpmn:outgoing>
    </bpmn:businessRuleTask>
    <bpmn:exclusiveGateway id="Gateway_SeriousDeviation" name="Závažná odchýlka/porucha?">
      <bpmn:incoming>Flow_ClassifyDeviation_To_SeriousDeviation</bpmn:incoming>
      <bpmn:outgoing>Flow_SeriousDeviation_Yes_To_TroubleshootingEnd</bpmn:outgoing>
      <bpmn:outgoing>Flow_SeriousDeviation_No_To_RequestOperatorIntervention</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sendTask id="Activity_RequestOperatorIntervention" name="Vyžiadaj zásah operátora">
      <bpmn:incoming>Flow_LimitsOk_No_To_RequestOperatorIntervention</bpmn:incoming>
      <bpmn:incoming>Flow_SeriousDeviation_No_To_RequestOperatorIntervention</bpmn:incoming>
      <bpmn:outgoing>Flow_RequestOperatorIntervention_To_ReviewDeviation</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:userTask id="Activity_ReviewDeviation" name="Preskúmaj odchýlku">
      <bpmn:incoming>Flow_RequestOperatorIntervention_To_ReviewDeviation</bpmn:incoming>
      <bpmn:outgoing>Flow_ReviewDeviation_To_NeedPhysicalCheck</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_NeedPhysicalCheck" name="Potrebná fyzická kontrola?">
      <bpmn:incoming>Flow_ReviewDeviation_To_NeedPhysicalCheck</bpmn:incoming>
      <bpmn:outgoing>Flow_NeedPhysicalCheck_Yes_To_PhysicalInspection</bpmn:outgoing>
      <bpmn:outgoing>Flow_NeedPhysicalCheck_No_To_EditParameters</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:manualTask id="Activity_PhysicalInspection" name="Fyzická kontrola turbíny">
      <bpmn:incoming>Flow_NeedPhysicalCheck_Yes_To_PhysicalInspection</bpmn:incoming>
      <bpmn:outgoing>Flow_PhysicalInspection_To_EditParameters</bpmn:outgoing>
    </bpmn:manualTask>
    <bpmn:userTask id="Activity_EditParameters" name="Uprav prevádzkové parametre">
      <bpmn:incoming>Flow_NeedPhysicalCheck_No_To_EditParameters</bpmn:incoming>
      <bpmn:incoming>Flow_PhysicalInspection_To_EditParameters</bpmn:incoming>
      <bpmn:outgoing>Flow_EditParameters_To_ApplyParameterChanges</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="Activity_ApplyParameterChanges" name="Aplikuj zmeny v systéme">
      <bpmn:incoming>Flow_EditParameters_To_ApplyParameterChanges</bpmn:incoming>
      <bpmn:outgoing>Flow_ApplyParameterChanges_To_LogChange</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Activity_LogChange" name="Zaznamenaj zmeny">
      <bpmn:incoming>Flow_ApplyParameterChanges_To_LogChange</bpmn:incoming>
      <bpmn:outgoing>Flow_LogChange_To_CollectSensorData</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="Activity_ConfirmCurtailment" name="Potvrď požiadavku DDS">
      <bpmn:incoming>Flow_CurtailmentRequest_To_ConfirmCurtailment</bpmn:incoming>
      <bpmn:outgoing>Flow_ConfirmCurtailment_To_AdjustSetpoint</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="Activity_AdjustSetpoint" name="Uprav setpoint výkonu">
      <bpmn:incoming>Flow_ConfirmCurtailment_To_AdjustSetpoint</bpmn:incoming>
      <bpmn:outgoing>Flow_AdjustSetpoint_To_ConfirmCurtailmentToDispatcher</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sendTask id="Activity_ConfirmCurtailmentToDispatcher" name="Odošli potvrdenie DDS">
      <bpmn:incoming>Flow_AdjustSetpoint_To_ConfirmCurtailmentToDispatcher</bpmn:incoming>
      <bpmn:outgoing>Flow_ConfirmCurtailmentToDispatcher_To_RecordCurtailment</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:userTask id="Activity_RecordCurtailment" name="Zaeviduj reguláciu v sieti">
      <bpmn:incoming>Flow_ConfirmCurtailmentToDispatcher_To_RecordCurtailment</bpmn:incoming>
      <bpmn:outgoing>Flow_RecordCurtailment_To_CollectSensorData</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="EndEvent_TransitionToTroubleshooting" name="Prechod na riešenie poruchy">
      <bpmn:incoming>Flow_SeriousDeviation_Yes_To_TroubleshootingEnd</bpmn:incoming>
      <bpmn:messageEventDefinition messageRef="Message_ToTroubleshooting" />
    </bpmn:endEvent>
    <bpmn:dataObject id="DataObject_OperatingParameters" />
    <bpmn:dataObjectReference id="DataObjectReference_OperatingParameters" name="Prevádzkové parametre" dataObjectRef="DataObject_OperatingParameters" />
    <bpmn:dataObject id="DataObject_ProductionData" />
    <bpmn:dataObjectReference id="DataObjectReference_ProductionData" name="Údaje o výrobe" dataObjectRef="DataObject_ProductionData" />
    <bpmn:dataObject id="DataObject_AlarmReport" />
    <bpmn:dataObjectReference id="DataObjectReference_AlarmReport" name="Alarm/odchýlka" dataObjectRef="DataObject_AlarmReport" />
    <bpmn:sequenceFlow id="Flow_Start_To_CollectSensorData" sourceRef="StartEvent_MonitoringStart" targetRef="Activity_CollectSensorData" />
    <bpmn:sequenceFlow id="Flow_CollectSensorData_To_PreprocessData" sourceRef="Activity_CollectSensorData" targetRef="Activity_PreprocessData" />
    <bpmn:sequenceFlow id="Flow_PreprocessData_To_ParallelMonitoringSplit" sourceRef="Activity_PreprocessData" targetRef="Gateway_ParallelMonitoringSplit" />
    <bpmn:sequenceFlow id="Flow_ParallelMonitoringSplit_To_MonitorWindAndPower" sourceRef="Gateway_ParallelMonitoringSplit" targetRef="Activity_MonitorWindAndPower" />
    <bpmn:sequenceFlow id="Flow_ParallelMonitoringSplit_To_MonitorTechIndicators" sourceRef="Gateway_ParallelMonitoringSplit" targetRef="Activity_MonitorTechIndicators" />
    <bpmn:sequenceFlow id="Flow_MonitorWindAndPower_To_ParallelMonitoringJoin" sourceRef="Activity_MonitorWindAndPower" targetRef="Gateway_ParallelMonitoringJoin" />
    <bpmn:sequenceFlow id="Flow_MonitorTechIndicators_To_ParallelMonitoringJoin" sourceRef="Activity_MonitorTechIndicators" targetRef="Gateway_ParallelMonitoringJoin" />
    <bpmn:sequenceFlow id="Flow_ParallelMonitoringJoin_To_WaitForEvent" sourceRef="Gateway_ParallelMonitoringJoin" targetRef="Gateway_WaitForEvent" />
    <bpmn:sequenceFlow id="Flow_WaitForEvent_To_Timer" name="Čas" sourceRef="Gateway_WaitForEvent" targetRef="Event_TimerInterval" />
    <bpmn:sequenceFlow id="Flow_WaitForEvent_To_DeviationMessage" name="Alarm" sourceRef="Gateway_WaitForEvent" targetRef="Event_MessageDeviationDetected" />
    <bpmn:sequenceFlow id="Flow_WaitForEvent_To_CurtailmentRequest" name="DDS" sourceRef="Gateway_WaitForEvent" targetRef="Event_MessageCurtailmentRequest" />
    <bpmn:sequenceFlow id="Flow_Timer_To_DataEvaluation" sourceRef="Event_TimerInterval" targetRef="Activity_DataEvaluation" />
    <bpmn:sequenceFlow id="Flow_DeviationMessage_To_DataEvaluation" sourceRef="Event_MessageDeviationDetected" targetRef="Activity_DataEvaluation" />
    <bpmn:sequenceFlow id="Flow_DataEvaluation_To_StableGateway" sourceRef="Activity_DataEvaluation" targetRef="Gateway_Stable" />
    <bpmn:sequenceFlow id="Flow_Stable_Yes_To_CalcOptimalSettings" name="Áno" sourceRef="Gateway_Stable" targetRef="Activity_CalcOptimalSettings" />
    <bpmn:sequenceFlow id="Flow_CalcOptimalSettings_To_ApplySettingsSplit" sourceRef="Activity_CalcOptimalSettings" targetRef="Gateway_ApplySettingsSplit" />
    <bpmn:sequenceFlow id="Flow_ApplySettingsSplit_To_AdjustPitch" sourceRef="Gateway_ApplySettingsSplit" targetRef="Activity_AdjustPitch" />
    <bpmn:sequenceFlow id="Flow_ApplySettingsSplit_To_AdjustYaw" sourceRef="Gateway_ApplySettingsSplit" targetRef="Activity_AdjustYaw" />
    <bpmn:sequenceFlow id="Flow_ApplySettingsSplit_To_AdjustConverter" sourceRef="Gateway_ApplySettingsSplit" targetRef="Activity_AdjustConverter" />
    <bpmn:sequenceFlow id="Flow_AdjustPitch_To_ApplySettingsJoin" sourceRef="Activity_AdjustPitch" targetRef="Gateway_ApplySettingsJoin" />
    <bpmn:sequenceFlow id="Flow_AdjustYaw_To_ApplySettingsJoin" sourceRef="Activity_AdjustYaw" targetRef="Gateway_ApplySettingsJoin" />
    <bpmn:sequenceFlow id="Flow_AdjustConverter_To_ApplySettingsJoin" sourceRef="Activity_AdjustConverter" targetRef="Gateway_ApplySettingsJoin" />
    <bpmn:sequenceFlow id="Flow_ApplySettingsJoin_To_ValidateLimits" sourceRef="Gateway_ApplySettingsJoin" targetRef="Activity_ValidateLimits" />
    <bpmn:sequenceFlow id="Flow_ValidateLimits_To_LimitsOk" sourceRef="Activity_ValidateLimits" targetRef="Gateway_LimitsOk" />
    <bpmn:sequenceFlow id="Flow_LimitsOk_Yes_To_SendProductionData" name="Áno" sourceRef="Gateway_LimitsOk" targetRef="Activity_SendProductionData" />
    <bpmn:sequenceFlow id="Flow_SendProductionData_To_RecordProductionData" sourceRef="Activity_SendProductionData" targetRef="Activity_RecordProductionData" />
    <bpmn:sequenceFlow id="Flow_RecordProductionData_To_CollectSensorData" name="Cyklus" sourceRef="Activity_RecordProductionData" targetRef="Activity_CollectSensorData" />
    <bpmn:sequenceFlow id="Flow_LimitsOk_No_To_RequestOperatorIntervention" name="Nie" sourceRef="Gateway_LimitsOk" targetRef="Activity_RequestOperatorIntervention" />
    <bpmn:sequenceFlow id="Flow_Stable_No_To_ClassifyDeviation" name="Nie" sourceRef="Gateway_Stable" targetRef="Activity_ClassifyDeviation" />
    <bpmn:sequenceFlow id="Flow_ClassifyDeviation_To_SeriousDeviation" sourceRef="Activity_ClassifyDeviation" targetRef="Gateway_SeriousDeviation" />
    <bpmn:sequenceFlow id="Flow_SeriousDeviation_No_To_RequestOperatorIntervention" name="Nie" sourceRef="Gateway_SeriousDeviation" targetRef="Activity_RequestOperatorIntervention" />
    <bpmn:sequenceFlow id="Flow_RequestOperatorIntervention_To_ReviewDeviation" sourceRef="Activity_RequestOperatorIntervention" targetRef="Activity_ReviewDeviation" />
    <bpmn:sequenceFlow id="Flow_ReviewDeviation_To_NeedPhysicalCheck" sourceRef="Activity_ReviewDeviation" targetRef="Gateway_NeedPhysicalCheck" />
    <bpmn:sequenceFlow id="Flow_NeedPhysicalCheck_Yes_To_PhysicalInspection" name="Áno" sourceRef="Gateway_NeedPhysicalCheck" targetRef="Activity_PhysicalInspection" />
    <bpmn:sequenceFlow id="Flow_PhysicalInspection_To_EditParameters" sourceRef="Activity_PhysicalInspection" targetRef="Activity_EditParameters" />
    <bpmn:sequenceFlow id="Flow_NeedPhysicalCheck_No_To_EditParameters" name="Nie" sourceRef="Gateway_NeedPhysicalCheck" targetRef="Activity_EditParameters" />
    <bpmn:sequenceFlow id="Flow_EditParameters_To_ApplyParameterChanges" sourceRef="Activity_EditParameters" targetRef="Activity_ApplyParameterChanges" />
    <bpmn:sequenceFlow id="Flow_ApplyParameterChanges_To_LogChange" sourceRef="Activity_ApplyParameterChanges" targetRef="Activity_LogChange" />
    <bpmn:sequenceFlow id="Flow_LogChange_To_CollectSensorData" name="Späť na monitoring" sourceRef="Activity_LogChange" targetRef="Activity_CollectSensorData" />
