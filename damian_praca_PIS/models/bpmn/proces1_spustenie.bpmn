<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  id="Definitions_Proces1"
  targetNamespace="http://bpmn.io/schema/bpmn"
  exporter="bpmn-js (https://demo.bpmn.io)"
  exporterVersion="18.6.1">

  <bpmn:message id="Message_GridApproved" name="Povolenie pripojenia udelené" />
  <bpmn:message id="Message_GridDenied" name="Povolenie pripojenia zamietnuté" />
  <bpmn:message id="Message_ProductionStarted" name="Výroba spustená" />

  <bpmn:process id="Process_StartProduction" name="Proces 1 – Spustenie výroby elektriny" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Proces1">
      <bpmn:lane id="Lane_ControlSystem" name="Riadiaci systém">
        <bpmn:flowNodeRef>StartEvent_Start</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_GetWindData</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_GetForecast</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_EvaluateStartConditions</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_WindOk</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_WaitForWind</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_TechnicalCheck</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_PreStartSplit</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_SafetyCheck</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_CalibrateSensors</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_PreStartJoin</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_AllChecksOk</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_RequestGridPermission</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_WaitGridResponse</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_GridApproved</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_GridDenied</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_GridTimeout</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_TurbineSetupSplit</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_YawAlignment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_PitchSetting</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_StartAuxSystems</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_TurbineSetupJoin</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_StartGenerator</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_RampUp</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_PostStartCheck</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_PostStartOk</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Terminated</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Aborted</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Operator" name="Operátor elektrárne">
        <bpmn:flowNodeRef>Activity_LaunchConfirmation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_ProductionStarted</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Dispatcher" name="Dispečer distribučnej siete">
        <bpmn:flowNodeRef>Activity_NetworkConnectionCheck</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="StartEvent_Start" name="Spustenie iniciované">
      <bpmn:outgoing>Flow_Start_To_GetWindData</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:serviceTask id="Activity_GetWindData" name="Získaj údaje o vetre">
      <bpmn:incoming>Flow_Start_To_GetWindData</bpmn:incoming>
      <bpmn:outgoing>Flow_GetWindData_To_GetForecast</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="Activity_GetForecast" name="Získaj krátkodobú predpoveď">
      <bpmn:incoming>Flow_GetWindData_To_GetForecast</bpmn:incoming>
      <bpmn:outgoing>Flow_GetForecast_To_EvaluateConditions</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:businessRuleTask id="Activity_EvaluateStartConditions" name="Vyhodnoť štartovacie podmienky">
      <bpmn:incoming>Flow_GetForecast_To_EvaluateConditions</bpmn:incoming>
      <bpmn:outgoing>Flow_EvaluateConditions_To_WindOk</bpmn:outgoing>
    </bpmn:businessRuleTask>

    <bpmn:exclusiveGateway id="Gateway_WindOk" name="Vietor vhodný?">
      <bpmn:incoming>Flow_EvaluateConditions_To_WindOk</bpmn:incoming>
      <bpmn:outgoing>Flow_WindOk_Yes_To_TechnicalCheck</bpmn:outgoing>
      <bpmn:outgoing>Flow_WindOk_No_To_WaitForWind</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:intermediateCatchEvent id="Event_WaitForWind" name="Čakať na vhodný vietor">
      <bpmn:incoming>Flow_WindOk_No_To_WaitForWind</bpmn:incoming>
      <bpmn:outgoing>Flow_WaitForWind_To_GetWindData</bpmn:outgoing>
      <bpmn:timerEventDefinition>
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT10M</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:intermediateCatchEvent>

    <bpmn:serviceTask id="Activity_TechnicalCheck" name="Skontroluj technický stav turbíny">
      <bpmn:incoming>Flow_WindOk_Yes_To_TechnicalCheck</bpmn:incoming>
      <bpmn:outgoing>Flow_TechnicalCheck_To_PreStartSplit</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:parallelGateway id="Gateway_PreStartSplit" name="Príprava na spustenie">
      <bpmn:incoming>Flow_TechnicalCheck_To_PreStartSplit</bpmn:incoming>
      <bpmn:outgoing>Flow_PreStartSplit_To_SafetyCheck</bpmn:outgoing>
      <bpmn:outgoing>Flow_PreStartSplit_To_CalibrateSensors</bpmn:outgoing>
      <bpmn:outgoing>Flow_PreStartSplit_To_NetworkCheck</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:serviceTask id="Activity_SafetyCheck" name="Skontroluj bezpečnostné limity">
      <bpmn:incoming>Flow_PreStartSplit_To_SafetyCheck</bpmn:incoming>
      <bpmn:outgoing>Flow_SafetyCheck_To_PreStartJoin</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="Activity_CalibrateSensors" name="Kalibruj senzory">
      <bpmn:incoming>Flow_PreStartSplit_To_CalibrateSensors</bpmn:incoming>
      <bpmn:outgoing>Flow_CalibrateSensors_To_PreStartJoin</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:userTask id="Activity_NetworkConnectionCheck" name="Over pripojenie do siete">
      <bpmn:incoming>Flow_PreStartSplit_To_NetworkCheck</bpmn:incoming>
      <bpmn:outgoing>Flow_NetworkCheck_To_PreStartJoin</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:parallelGateway id="Gateway_PreStartJoin" name="Príprava dokončená">
      <bpmn:incoming>Flow_SafetyCheck_To_PreStartJoin</bpmn:incoming>
      <bpmn:incoming>Flow_CalibrateSensors_To_PreStartJoin</bpmn:incoming>
      <bpmn:incoming>Flow_NetworkCheck_To_PreStartJoin</bpmn:incoming>
      <bpmn:outgoing>Flow_PreStartJoin_To_AllChecksOk</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:exclusiveGateway id="Gateway_AllChecksOk" name="Všetky kontroly OK?">
      <bpmn:incoming>Flow_PreStartJoin_To_AllChecksOk</bpmn:incoming>
      <bpmn:outgoing>Flow_AllChecksOk_Yes_To_RequestGridPermission</bpmn:outgoing>
      <bpmn:outgoing>Flow_AllChecksOk_No_To_Aborted</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="Activity_RequestGridPermission" name="Požiadaj o povolenie pripojenia">
      <bpmn:incoming>Flow_AllChecksOk_Yes_To_RequestGridPermission</bpmn:incoming>
      <bpmn:outgoing>Flow_RequestGridPermission_To_WaitGridResponse</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:eventBasedGateway id="Gateway_WaitGridResponse" name="Čakaj na odpoveď">
      <bpmn:incoming>Flow_RequestGridPermission_To_WaitGridResponse</bpmn:incoming>
      <bpmn:outgoing>Flow_WaitGridResponse_To_Approved</bpmn:outgoing>
      <bpmn:outgoing>Flow_WaitGridResponse_To_Denied</bpmn:outgoing>
      <bpmn:outgoing>Flow_WaitGridResponse_To_Timeout</bpmn:outgoing>
    </bpmn:eventBasedGateway>

    <bpmn:intermediateCatchEvent id="Event_GridApproved" name="Povolenie udelené">
      <bpmn:incoming>Flow_WaitGridResponse_To_Approved</bpmn:incoming>
      <bpmn:outgoing>Flow_Approved_To_TurbineSetupSplit</bpmn:outgoing>
      <bpmn:messageEventDefinition messageRef="Message_GridApproved" />
    </bpmn:intermediateCatchEvent>

    <bpmn:intermediateCatchEvent id="Event_GridDenied" name="Povolenie zamietnuté">
      <bpmn:incoming>Flow_WaitGridResponse_To_Denied</bpmn:incoming>
      <bpmn:outgoing>Flow_Denied_To_Terminated</bpmn:outgoing>
      <bpmn:messageEventDefinition messageRef="Message_GridDenied" />
    </bpmn:intermediateCatchEvent>

    <bpmn:intermediateCatchEvent id="Event_GridTimeout" name="Časový limit">
      <bpmn:incoming>Flow_WaitGridResponse_To_Timeout</bpmn:incoming>
      <bpmn:outgoing>Flow_Timeout_To_Terminated</bpmn:outgoing>
      <bpmn:timerEventDefinition>
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT2M</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:intermediateCatchEvent>

    <bpmn:parallelGateway id="Gateway_TurbineSetupSplit" name="Nastavenie turbíny">
      <bpmn:incoming>Flow_Approved_To_TurbineSetupSplit</bpmn:incoming>
      <bpmn:outgoing>Flow_TurbineSetupSplit_To_Yaw</bpmn:outgoing>
      <bpmn:outgoing>Flow_TurbineSetupSplit_To_Pitch</bpmn:outgoing>
      <bpmn:outgoing>Flow_TurbineSetupSplit_To_Aux</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:serviceTask id="Activity_YawAlignment" name="Natoč gondolu (yaw)">
      <bpmn:incoming>Flow_TurbineSetupSplit_To_Yaw</bpmn:incoming>
      <bpmn:outgoing>Flow_Yaw_To_TurbineSetupJoin</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="Activity_PitchSetting" name="Nastav uhol lopatiek (pitch)">
      <bpmn:incoming>Flow_TurbineSetupSplit_To_Pitch</bpmn:incoming>
      <bpmn:outgoing>Flow_Pitch_To_TurbineSetupJoin</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="Activity_StartAuxSystems" name="Spusť pomocné systémy">
      <bpmn:incoming>Flow_TurbineSetupSplit_To_Aux</bpmn:incoming>
      <bpmn:outgoing>Flow_Aux_To_TurbineSetupJoin</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:parallelGateway id="Gateway_TurbineSetupJoin" name="Turbína pripravená">
      <bpmn:incoming>Flow_Yaw_To_TurbineSetupJoin</bpmn:incoming>
      <bpmn:incoming>Flow_Pitch_To_TurbineSetupJoin</bpmn:incoming>
      <bpmn:incoming>Flow_Aux_To_TurbineSetupJoin</bpmn:incoming>
      <bpmn:outgoing>Flow_TurbineSetupJoin_To_StartGenerator</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:serviceTask id="Activity_StartGenerator" name="Spusť generátor">
      <bpmn:incoming>Flow_TurbineSetupJoin_To_StartGenerator</bpmn:incoming>
      <bpmn:outgoing>Flow_StartGenerator_To_RampUp</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:scriptTask id="Activity_RampUp" name="Postupné nabiehanie výkonu">
      <bpmn:incoming>Flow_StartGenerator_To_RampUp</bpmn:incoming>
      <bpmn:outgoing>Flow_RampUp_To_PostStartCheck</bpmn:outgoing>
    </bpmn:scriptTask>

    <bpmn:serviceTask id="Activity_PostStartCheck" name="Kontrola po štarte">
      <bpmn:incoming>Flow_RampUp_To_PostStartCheck</bpmn:incoming>
      <bpmn:outgoing>Flow_PostStartCheck_To_PostStartOk</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:exclusiveGateway id="Gateway_PostStartOk" name="Štart prebehol OK?">
      <bpmn:incoming>Flow_PostStartCheck_To_PostStartOk</bpmn:incoming>
      <bpmn:outgoing>Flow_PostStartOk_Yes_To_LaunchConfirmation</bpmn:outgoing>
      <bpmn:outgoing>Flow_PostStartOk_No_To_Aborted</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="Activity_LaunchConfirmation" name="Potvrď spustenie výroby">
      <bpmn:incoming>Flow_PostStartOk_Yes_To_LaunchConfirmation</bpmn:incoming>
      <bpmn:outgoing>Flow_LaunchConfirmation_To_ProductionStarted</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:endEvent id="EndEvent_ProductionStarted" name="Výroba spustená">
      <bpmn:incoming>Flow_LaunchConfirmation_To_ProductionStarted</bpmn:incoming>
      <bpmn:messageEventDefinition messageRef="Message_ProductionStarted" />
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_Terminated" name="Proces ukončený">
      <bpmn:incoming>Flow_Denied_To_Terminated</bpmn:incoming>
      <bpmn:incoming>Flow_Timeout_To_Terminated</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_Aborted" name="Spustenie zrušené">
      <bpmn:incoming>Flow_AllChecksOk_No_To_Aborted</bpmn:incoming>
      <bpmn:incoming>Flow_PostStartOk_No_To_Aborted</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:dataObject id="DataObject_WindData" />
    <bpmn:dataObjectReference id="DataObjectReference_WindData" name="Údaje o vetre" dataObjectRef="DataObject_WindData" />
    <bpmn:dataObject id="DataObject_Forecast" />
    <bpmn:dataObjectReference id="DataObjectReference_Forecast" name="Predpoveď" dataObjectRef="DataObject_Forecast" />
    <bpmn:dataObject id="DataObject_CheckReport" />
    <bpmn:dataObjectReference id="DataObjectReference_CheckReport" name="Report kontrol" dataObjectRef="DataObject_CheckReport" />

    <bpmn:sequenceFlow id="Flow_Start_To_GetWindData" sourceRef="StartEvent_Start" targetRef="Activity_GetWindData" />
    <bpmn:sequenceFlow id="Flow_GetWindData_To_GetForecast" sourceRef="Activity_GetWindData" targetRef="Activity_GetForecast" />
    <bpmn:sequenceFlow id="Flow_GetForecast_To_EvaluateConditions" sourceRef="Activity_GetForecast" targetRef="Activity_EvaluateStartConditions" />
    <bpmn:sequenceFlow id="Flow_EvaluateConditions_To_WindOk" sourceRef="Activity_EvaluateStartConditions" targetRef="Gateway_WindOk" />
    <bpmn:sequenceFlow id="Flow_WindOk_No_To_WaitForWind" sourceRef="Gateway_WindOk" targetRef="Event_WaitForWind" name="Nie" />
    <bpmn:sequenceFlow id="Flow_WaitForWind_To_GetWindData" sourceRef="Event_WaitForWind" targetRef="Activity_GetWindData" name="Opakuj" />
    <bpmn:sequenceFlow id="Flow_WindOk_Yes_To_TechnicalCheck" sourceRef="Gateway_WindOk" targetRef="Activity_TechnicalCheck" name="Áno" />
    <bpmn:sequenceFlow id="Flow_TechnicalCheck_To_PreStartSplit" sourceRef="Activity_TechnicalCheck" targetRef="Gateway_PreStartSplit" />
    <bpmn:sequenceFlow id="Flow_PreStartSplit_To_SafetyCheck" sourceRef="Gateway_PreStartSplit" targetRef="Activity_SafetyCheck" name="Súbežne" />
    <bpmn:sequenceFlow id="Flow_PreStartSplit_To_CalibrateSensors" sourceRef="Gateway_PreStartSplit" targetRef="Activity_CalibrateSensors" name="Súbežne" />
    <bpmn:sequenceFlow id="Flow_PreStartSplit_To_NetworkCheck" sourceRef="Gateway_PreStartSplit" targetRef="Activity_NetworkConnectionCheck" name="Súbežne" />
    <bpmn:sequenceFlow id="Flow_SafetyCheck_To_PreStartJoin" sourceRef="Activity_SafetyCheck" targetRef="Gateway_PreStartJoin" />
    <bpmn:sequenceFlow id="Flow_CalibrateSensors_To_PreStartJoin" sourceRef="Activity_CalibrateSensors" targetRef="Gateway_PreStartJoin" />
    <bpmn:sequenceFlow id="Flow_NetworkCheck_To_PreStartJoin" sourceRef="Activity_NetworkConnectionCheck" targetRef="Gateway_PreStartJoin" />
    <bpmn:sequenceFlow id="Flow_PreStartJoin_To_AllChecksOk" sourceRef="Gateway_PreStartJoin" targetRef="Gateway_AllChecksOk" />
    <bpmn:sequenceFlow id="Flow_AllChecksOk_No_To_Aborted" sourceRef="Gateway_AllChecksOk" targetRef="EndEvent_Aborted" name="Nie" />
    <bpmn:sequenceFlow id="Flow_AllChecksOk_Yes_To_RequestGridPermission" sourceRef="Gateway_AllChecksOk" targetRef="Activity_RequestGridPermission" name="Áno" />
    <bpmn:sequenceFlow id="Flow_RequestGridPermission_To_WaitGridResponse" sourceRef="Activity_RequestGridPermission" targetRef="Gateway_WaitGridResponse" />
    <bpmn:sequenceFlow id="Flow_WaitGridResponse_To_Approved" sourceRef="Gateway_WaitGridResponse" targetRef="Event_GridApproved" name="Schválené" />
    <bpmn:sequenceFlow id="Flow_WaitGridResponse_To_Denied" sourceRef="Gateway_WaitGridResponse" targetRef="Event_GridDenied" name="Zamietnuté" />
    <bpmn:sequenceFlow id="Flow_WaitGridResponse_To_Timeout" sourceRef="Gateway_WaitGridResponse" targetRef="Event_GridTimeout" name="Timeout" />
    <bpmn:sequenceFlow id="Flow_Approved_To_TurbineSetupSplit" sourceRef="Event_GridApproved" targetRef="Gateway_TurbineSetupSplit" />
    <bpmn:sequenceFlow id="Flow_Denied_To_Terminated" sourceRef="Event_GridDenied" targetRef="EndEvent_Terminated" />
    <bpmn:sequenceFlow id="Flow_Timeout_To_Terminated" sourceRef="Event_GridTimeout" targetRef="EndEvent_Terminated" />
    <bpmn:sequenceFlow id="Flow_TurbineSetupSplit_To_Yaw" sourceRef="Gateway_TurbineSetupSplit" targetRef="Activity_YawAlignment" name="Súbežne" />
    <bpmn:sequenceFlow id="Flow_TurbineSetupSplit_To_Pitch" sourceRef="Gateway_TurbineSetupSplit" targetRef="Activity_PitchSetting" name="Súbežne" />
    <bpmn:sequenceFlow id="Flow_TurbineSetupSplit_To_Aux" sourceRef="Gateway_TurbineSetupSplit" targetRef="Activity_StartAuxSystems" name="Súbežne" />
    <bpmn:sequenceFlow id="Flow_Yaw_To_TurbineSetupJoin" sourceRef="Activity_YawAlignment" targetRef="Gateway_TurbineSetupJoin" />
    <bpmn:sequenceFlow id="Flow_Pitch_To_TurbineSetupJoin" sourceRef="Activity_PitchSetting" targetRef="Gateway_TurbineSetupJoin" />
    <bpmn:sequenceFlow id="Flow_Aux_To_TurbineSetupJoin" sourceRef="Activity_StartAuxSystems" targetRef="Gateway_TurbineSetupJoin" />
    <bpmn:sequenceFlow id="Flow_TurbineSetupJoin_To_StartGenerator" sourceRef="Gateway_TurbineSetupJoin" targetRef="Activity_StartGenerator" />
    <bpmn:sequenceFlow id="Flow_StartGenerator_To_RampUp" sourceRef="Activity_StartGenerator" targetRef="Activity_RampUp" />
    <bpmn:sequenceFlow id="Flow_RampUp_To_PostStartCheck" sourceRef="Activity_RampUp" targetRef="Activity_PostStartCheck" />
    <bpmn:sequenceFlow id="Flow_PostStartCheck_To_PostStartOk" sourceRef="Activity_PostStartCheck" targetRef="Gateway_PostStartOk" />
    <bpmn:sequenceFlow id="Flow_PostStartOk_Yes_To_LaunchConfirmation" sourceRef="Gateway_PostStartOk" targetRef="Activity_LaunchConfirmation" name="Áno" />
    <bpmn:sequenceFlow id="Flow_PostStartOk_No_To_Aborted" sourceRef="Gateway_PostStartOk" targetRef="EndEvent_Aborted" name="Nie" />
    <bpmn:sequenceFlow id="Flow_LaunchConfirmation_To_ProductionStarted" sourceRef="Activity_LaunchConfirmation" targetRef="EndEvent_ProductionStarted" />
  </bpmn:process>
</bpmn:definitions>
